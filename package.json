{
  "name": "feed2md-workspace",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "changeset": "changeset",
    "clean": "pnpm -r --if-present clean && rm -rf coverage dist",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm --filter @myx0m0p/feed2md build && pnpm -r --if-present lint",
    "release": "changeset publish",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm --filter @myx0m0p/feed2md test:coverage",
    "test:watch": "pnpm --filter @myx0m0p/feed2md test:watch",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
